<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>steeproute — route {{ route_index }}</title>
<style>{{ leaflet_css | safe }}</style>
<style>
  body { font-family: system-ui, -apple-system, sans-serif; margin: 0; padding: 1.5rem;
         color: #1a1a1a; background: #fafafa; }
  h1 { font-size: 1.4rem; margin: 0 0 1rem; }
  h2 { font-size: 1.05rem; margin: 1.5rem 0 0.5rem; }
  #map { height: 420px; border: 1px solid #ccc; border-radius: 4px; }
  #elevation-profile { max-width: 100%; }
  .banner { background: #b00020; color: #fff; padding: 1rem 1.25rem; border-radius: 4px;
            margin-bottom: 1.25rem; }
  .banner h2 { color: #fff; margin-top: 0; }
  .banner ul { margin: 0.25rem 0 0; padding-left: 1.25rem; }
  table.meta { border-collapse: collapse; font-size: 0.9rem; }
  table.meta th, table.meta td { text-align: left; padding: 0.2rem 0.9rem 0.2rem 0;
                                 vertical-align: top; }
  table.meta th { color: #555; font-weight: 600; white-space: nowrap; }
  .metrics { display: flex; gap: 2rem; flex-wrap: wrap; }
  .metrics div { font-size: 0.95rem; }
  .metrics .val { font-size: 1.25rem; font-weight: 700; }
  footer { margin-top: 2rem; color: #777; font-size: 0.8rem; }
</style>
</head>
<body>

{% if show_banner %}
<div class="banner" role="alert">
  <h2>⚠ VALIDATION FAILED</h2>
  <p>This route violates one or more declared constraints and is presented for transparency only.</p>
  <ul>
    {% for v in validation.violations %}
    <li><strong>{{ v.constraint_id }}</strong>: {{ v.detail }}
        (observed {{ v.numeric.observed }}, required {{ v.numeric.required }})</li>
    {% endfor %}
    {% for pv in pairwise %}
    <li><strong>distinctness</strong>: too similar to route {{ pv.other_index }}
        (Jaccard {{ pv.jaccard_observed }} &gt; max {{ pv.jaccard_max }})</li>
    {% endfor %}
  </ul>
</div>
{% endif %}

<h1>steeproute — route {{ route_index }}</h1>

<div class="metrics">
  <div><div class="val">{{ "%.0f"|format(metrics.length_m) }} m</div>length</div>
  <div><div class="val">{{ "%.0f"|format(metrics.d_plus_m) }} m</div>D+</div>
  <div><div class="val">{{ "%.0f"|format(metrics.d_minus_m) }} m</div>D−</div>
  <div><div class="val">{{ "%.1f"|format(metrics.avg_gradient * 100) }} %</div>avg gradient</div>
</div>

{% if has_geometry %}
<h2>Map</h2>
<div id="map"></div>

<h2>Elevation profile</h2>
<canvas id="elevation-profile" height="120"></canvas>
{% else %}
<h2>Geometry</h2>
<p><em>Route geometry is unavailable — the map and elevation profile are omitted for this route.</em></p>
{% endif %}

<h2>Run metadata</h2>
<table class="meta">
  <tr><th>convergence</th><td>{{ metadata.convergence_status }}</td></tr>
  <tr><th>validation</th><td>{{ "passed" if validation.passed else "FAILED" }}</td></tr>
  {% for k, v in metadata.params.items() %}
  <tr><th>{{ k }}</th><td>{{ v }}</td></tr>
  {% endfor %}
  {% for k, v in metadata.provenance.items() %}
  <tr><th>{{ k }}</th><td>{{ v }}</td></tr>
  {% endfor %}
  <tr><th>leaflet_version</th><td>{{ metadata.assets.leaflet }}</td></tr>
  <tr><th>chart_js_version</th><td>{{ metadata.assets.chart_js }}</td></tr>
</table>

<footer>
  Generated by steeproute {{ metadata.provenance.steeproute_version }}
  (commit {{ metadata.provenance.git_commit }}).
  Leaflet {{ metadata.assets.leaflet }} + Chart.js {{ metadata.assets.chart_js }}, inlined — self-contained report.
</footer>

<script>{{ leaflet_js | safe }}</script>
<script>{{ chart_js | safe }}</script>
{% if has_geometry %}
<script>
  // --- Route geometry (GeoJSON LineString, [lon, lat] order) ---
  const routeGeoJSON = {{ route_geojson | tojson }};
  const map = L.map("map");
  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
    maxZoom: 19,
    attribution: "&copy; OpenStreetMap contributors",
  }).addTo(map);
  const line = L.geoJSON(routeGeoJSON, { style: { color: "#b00020", weight: 4 } }).addTo(map);
  map.fitBounds(line.getBounds(), { padding: [20, 20] });

  // --- Elevation profile with gradient-colored segments ---
  const distances = {{ profile_distances | tojson }};
  const elevations = {{ profile_elevations | tojson }};
  function gradientColor(g) {
    // g = rise/run fraction; green (flat/descending) -> red (steep climb).
    const t = Math.max(0, Math.min(0.3, g)) / 0.3;
    const r = Math.round(70 + t * 175);
    const grn = Math.round(160 - t * 130);
    return `rgb(${r},${grn},70)`;
  }
  new Chart(document.getElementById("elevation-profile"), {
    type: "line",
    data: {
      labels: distances.map((d) => (d / 1000).toFixed(2)),
      datasets: [{
        data: elevations,
        fill: false,
        pointRadius: 0,
        borderWidth: 3,
        segment: {
          borderColor: (ctx) => {
            const i = ctx.p0DataIndex;
            const run = distances[i + 1] - distances[i];
            const rise = elevations[i + 1] - elevations[i];
            return gradientColor(run > 0 ? rise / run : 0);
          },
        },
      }],
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        x: { title: { display: true, text: "distance (km)" } },
        y: { title: { display: true, text: "elevation (m)" } },
      },
    },
  });
</script>
{% endif %}
</body>
</html>
