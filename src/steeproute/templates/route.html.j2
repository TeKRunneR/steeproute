<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>steeproute — route {{ route_index }}</title>
<style>{{ leaflet_css | safe }}</style>
<style>
  body { font-family: system-ui, -apple-system, sans-serif; margin: 0; padding: 1.5rem;
         color: #1a1a1a; background: #fafafa; }
  h1 { font-size: 1.4rem; margin: 0 0 1rem; }
  h2 { font-size: 1.05rem; margin: 1.5rem 0 0.5rem; }
  #map { height: 462px; border: 1px solid #ccc; border-radius: 4px; }
  /* Fixed-height, position:relative wrapper is Chart.js's documented pattern for
     responsive + maintainAspectRatio:false; the canvas fills it exactly. */
  #elevation-profile-wrap { position: relative; height: 180px; }
  #elevation-profile { display: block; width: 100%; height: 100%; }
  .banner { background: #b00020; color: #fff; padding: 1rem 1.25rem; border-radius: 4px;
            margin-bottom: 1.25rem; }
  .banner h2 { color: #fff; margin-top: 0; }
  .banner ul { margin: 0.25rem 0 0; padding-left: 1.25rem; }
  table.meta { border-collapse: collapse; font-size: 0.9rem; }
  table.meta th, table.meta td { text-align: left; padding: 0.2rem 0.9rem 0.2rem 0;
                                 vertical-align: top; }
  table.meta th { color: #555; font-weight: 600; white-space: nowrap; }
  .metrics { display: flex; gap: 2rem; flex-wrap: wrap; }
  .metrics div { font-size: 0.95rem; }
  .metrics .val { font-size: 1.25rem; font-weight: 700; }
  footer { margin-top: 2rem; color: #777; font-size: 0.8rem; }
</style>
</head>
<body>

{% if show_banner %}
<div class="banner" role="alert">
  <h2>⚠ VALIDATION FAILED</h2>
  <p>This route violates one or more declared constraints and is presented for transparency only.</p>
  <ul>
    {% for v in validation.violations %}
    <li><strong>{{ v.constraint_id }}</strong>: {{ v.detail }}
        (observed {{ v.numeric.observed }}, required {{ v.numeric.required }})</li>
    {% endfor %}
    {% for pv in pairwise %}
    <li><strong>distinctness</strong>: too similar to route {{ pv.other_index }}
        (Jaccard {{ pv.jaccard_observed }} &gt; max {{ pv.jaccard_max }})</li>
    {% endfor %}
  </ul>
</div>
{% endif %}

<h1>steeproute — route {{ route_index }}</h1>

<div class="metrics">
  <div><div class="val">{{ "%.0f"|format(metrics.length_m) }} m</div>length</div>
  <div><div class="val">{{ "%.0f"|format(metrics.d_plus_m) }} m</div>D+</div>
  <div><div class="val">{{ "%.0f"|format(metrics.d_minus_m) }} m</div>D−</div>
  <div><div class="val">{{ "%.1f"|format(metrics.avg_gradient * 100) }} %</div>avg gradient</div>
</div>

{% if has_geometry %}
<h2>Map</h2>
<div id="map"></div>

<h2>Elevation profile</h2>
<div id="elevation-profile-wrap"><canvas id="elevation-profile"></canvas></div>
{% else %}
<h2>Geometry</h2>
<p><em>Route geometry is unavailable — the map and elevation profile are omitted for this route.</em></p>
{% endif %}

<h2>Run metadata</h2>
<table class="meta">
  <tr><th>convergence</th><td>{{ metadata.convergence_status }}</td></tr>
  <tr><th>convergence_iteration</th><td>{{ metadata.convergence_iteration }}</td></tr>
  <tr><th>validation</th><td>{{ "passed" if validation.passed else "FAILED" }}</td></tr>
  {% for k, v in metadata.params.items() %}
  <tr><th>{{ k }}</th><td>{{ v }}</td></tr>
  {% endfor %}
  {% for k, v in metadata.provenance.items() %}
  <tr><th>{{ k }}</th><td>{{ v }}</td></tr>
  {% endfor %}
  <tr><th>leaflet_version</th><td>{{ metadata.assets.leaflet }}</td></tr>
  <tr><th>chart_js_version</th><td>{{ metadata.assets.chart_js }}</td></tr>
</table>

<footer>
  Generated by steeproute {{ metadata.provenance.steeproute_version }}
  (commit {{ metadata.provenance.git_commit }}).
  Leaflet {{ metadata.assets.leaflet }} + Chart.js {{ metadata.assets.chart_js }}, inlined — self-contained report.
</footer>

<script>{{ leaflet_js | safe }}</script>
<script>{{ chart_js | safe }}</script>
{% if has_geometry %}
<script>
  // --- Route geometry (GeoJSON LineString, [lon, lat] order) ---
  const routeGeoJSON = {{ route_geojson | tojson }};
  const map = L.map("map");
  // OSM-derived OpenTopoMap basemap: topographic style rendering hiking trails,
  // paths, and contour lines — far more useful for placing a route than a low-detail
  // viz basemap. Referer-tolerant and key-free, so it loads from a file:// report
  // (unlike tile.openstreetmap.org, which now 403s referer-less requests).
  L.tileLayer("https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png", {
    maxZoom: 17,
    subdomains: "abc",
    referrerPolicy: "strict-origin-when-cross-origin",
    attribution:
      "Map data &copy; OpenStreetMap contributors, SRTM | " +
      "Style: &copy; OpenTopoMap (CC-BY-SA)",
  }).addTo(map);
  // Search-area overlay: the 2*radius_km query bbox as a thin stroke-only
  // rectangle, added BEFORE the route so the red polyline draws on top. Stroke
  // only (no fill) so it covers minimal area; dashed gray-blue to read as a
  // secondary marker distinct from the route's #b00020.
  const searchBbox = {{ search_bbox | tojson }};
  L.rectangle(
    [[searchBbox.south, searchBbox.west], [searchBbox.north, searchBbox.east]],
    { color: "#5a6b8c", weight: 2, fill: false, dashArray: "6 4" }
  ).addTo(map);

  const line = L.geoJSON(routeGeoJSON, { style: { color: "#b00020", weight: 4 } }).addTo(map);
  // Initial view stays fitted to the ROUTE, not the box — inspecting a single
  // route is the primary use; the rectangle may fall off-screen on open (intended).
  map.fitBounds(line.getBounds(), { padding: [20, 20] });

  // --- Elevation profile with gradient-colored segments ---
  const distances = {{ profile_distances | tojson }};
  const elevations = {{ profile_elevations | tojson }};
  // Cumulative ascent/descent up to each vertex, so the hover can show how much
  // of the route's total D+/D- has accrued by that point. Because the displayed
  // curve and the metric are one canonical profile (Story 6.3), these reach the
  // box totals at the final vertex — a one-glance box==curve consistency check.
  const cumUp = [];
  const cumDown = [];
  (() => {
    let up = 0, down = 0;
    for (let i = 0; i < elevations.length; i++) {
      if (i > 0) {
        const d = elevations[i] - elevations[i - 1];
        if (d > 0) up += d; else down -= d;
      }
      cumUp.push(up);
      cumDown.push(down);
    }
  })();
  // Displayed slope is measured over a multi-vertex baseline rather than a single
  // ~10 m resample segment: a single segment spikes to implausible values (a 58%
  // reading on an 8.6% trail, extreme spikes where a route nearly doubles back
  // over a sub-5 m end-segment). +-2 vertices (~40 m baseline at the 10 m spacing)
  // reads the terrain a hiker feels while still resolving genuine pitches.
  const SLOPE_BASELINE_VERTS = 2;
  function baselineSlope(i) {
    const last = elevations.length - 1;
    const a = Math.max(0, i - SLOPE_BASELINE_VERTS);
    const b = Math.min(last, i + SLOPE_BASELINE_VERTS);
    const run = distances[b] - distances[a];
    return run > 0 ? (elevations[b] - elevations[a]) / run : 0;
  }
  function gradientColor(s) {
    // s = signed rise/run fraction. Diverging scheme legible on white:
    //   descending (s<0) -> blue, flat (s~0) -> neutral gray, ascending (s>0) -> red,
    // each scaled by steepness with |s| clamped to tan(30 deg) ~= 0.58 (58% grade)
    // so steep alpine terrain spans the full color range instead of pinning
    // red/blue from a 30% grade upward.
    const CLAMP = 0.58;
    const neutral = [170, 170, 170];
    const up = [200, 30, 30];     // steep ascent
    const down = [30, 90, 200];   // steep descent
    const end = s >= 0 ? up : down;
    const t = Math.min(Math.abs(s), CLAMP) / CLAMP;
    const r = Math.round(neutral[0] + t * (end[0] - neutral[0]));
    const grn = Math.round(neutral[1] + t * (end[1] - neutral[1]));
    const b = Math.round(neutral[2] + t * (end[2] - neutral[2]));
    return `rgb(${r},${grn},${b})`;
  }
  const profileChart = new Chart(document.getElementById("elevation-profile"), {
    type: "line",
    data: {
      labels: distances.map((d) => (d / 1000).toFixed(2)),
      datasets: [{
        data: elevations,
        fill: false,
        pointRadius: 0,
        pointHoverRadius: 5,
        pointHoverBackgroundColor: "#0066ff",
        borderWidth: 3,
        segment: {
          borderColor: (ctx) => {
            // Color the segment by the baseline slope straddling it (mean of the
            // baseline slope at its two endpoints) rather than its own ~10 m
            // rise/run, so a single noisy segment can't paint a false-steep band.
            const i = ctx.p0DataIndex;
            return gradientColor((baselineSlope(i) + baselineSlope(i + 1)) / 2);
          },
        },
      }],
    },
    options: {
      responsive: true,
      // Fill the fixed-height #elevation-profile-wrap instead of preserving the
      // canvas aspect ratio, which would otherwise scale the profile's height with
      // the screen width — far too tall to view alongside the map on a 1080p screen.
      maintainAspectRatio: false,
      interaction: { mode: "index", intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            // Signed slope over the multi-vertex baseline (see baselineSlope),
            // plus how much D+/D- has accrued so far — the latter reaches the box
            // totals at the final vertex (box==curve). run==0 is treated as flat.
            afterLabel: (ctx) => {
              const i = ctx.dataIndex;
              const pct = Math.round(baselineSlope(i) * 100);
              const sign = pct > 0 ? "+" : pct < 0 ? "-" : "";
              return [
                `slope: ${sign}${Math.abs(pct)}%`,
                `D+ so far: ${Math.round(cumUp[i])} m`,
                `D- so far: ${Math.round(cumDown[i])} m`,
              ];
            },
          },
        },
      },
      scales: {
        x: { title: { display: true, text: "distance (km)" } },
        y: { title: { display: true, text: "elevation (m)" } },
      },
      onHover: (_event, elements) => {
        // Profile -> map: hovering a profile point marks the route on the map.
        if (elements && elements.length) {
          showHighlight(elements[0].index);
        } else {
          hideHighlight();
        }
      },
    },
  });

  // --- Map <-> elevation-profile hover linking ---
  // routeGeoJSON coordinate i and profile point i are the same resampled vertex
  // (output.py builds both from one ordered vertex list), so linking the two views
  // is just sharing that index — no distance interpolation needed.
  const coords = routeGeoJSON.features[0].geometry.coordinates; // [lon, lat]
  const latlngs = coords.map((c) => [c[1], c[0]]); // Leaflet wants [lat, lon]
  const highlight = L.circleMarker([0, 0], {
    radius: 6, color: "#0066ff", weight: 2, fillColor: "#0066ff", fillOpacity: 0.9,
  });
  let highlightOn = false;
  function showHighlight(i) {
    if (i < 0 || i >= latlngs.length) return;
    highlight.setLatLng(latlngs[i]);
    if (!highlightOn) { highlight.addTo(map); highlightOn = true; }
  }
  function hideHighlight() {
    if (highlightOn) { map.removeLayer(highlight); highlightOn = false; }
  }
  function activateProfile(i) {
    const pt = profileChart.getDatasetMeta(0).data[i];
    const pos = pt ? { x: pt.x, y: pt.y } : { x: 0, y: 0 };
    profileChart.setActiveElements([{ datasetIndex: 0, index: i }]);
    profileChart.tooltip.setActiveElements([{ datasetIndex: 0, index: i }], pos);
    profileChart.update();
  }
  function clearProfile() {
    profileChart.setActiveElements([]);
    profileChart.tooltip.setActiveElements([], { x: 0, y: 0 });
    profileChart.update();
  }
  // Map -> profile: hovering the route highlights the matching profile point.
  line.on("mousemove", (e) => {
    let best = -1, bestD = Infinity;
    for (let i = 0; i < latlngs.length; i++) {
      const dlat = latlngs[i][0] - e.latlng.lat;
      const dlon = latlngs[i][1] - e.latlng.lng;
      const d = dlat * dlat + dlon * dlon;
      if (d < bestD) { bestD = d; best = i; }
    }
    if (best >= 0) { showHighlight(best); activateProfile(best); }
  });
  line.on("mouseout", () => { hideHighlight(); clearProfile(); });
</script>
{% endif %}
</body>
</html>
